chassis {
    fpc 0 {
        sampling-instance instance-1;
        inline-services {
            flow-table-size {
                ipv4-flow-table-size 7;
            }
        }
    }
}
services {
    flow-monitoring {
        version-ipfix {
            template ipix {
                flow-active-timeout 100;
                flow-inactive-timeout 50;
                template-refresh-rate {
                    seconds 10;
                }
                ipv4-template;          
            }                           
        }                               
    }                                   
} 
interfaces {
    ge-0/0/0 {
        unit 0 {
            family inet {
                filter {                
                    input inet-sample;  
                } 
                address 10.10.0.6/31;
            }
        }
    }
    ge-0/0/1 {
        unit 0 {
            family inet {
            	filter {                
                    input inet-sample;  
                }
                address 10.10.0.8/31;
            }
        }
    }
    ge-0/0/2 {
        unit 0 {
            family inet {
            	filter {                
                    input inet-sample;  
                }
                address 10.10.0.10/31;
            }
        }
    }
    ge-0/0/3 {
        unit 0 {
            family inet {
                address 172.10.10.24/24;
            }
        }
    }
}
snmp {                                  
    view all {                          
        oid .1;                         
    }                                   
    client-list 172.10.10.203;          
    community public {                  
        view all;                       
        authorization read-write;       
        clients {                       
            172.10.10.0/24;             
        }                               
    }                                   
} 
forwarding-options {                    
    sampling {                          
        instance {                      
            instance-1 {                
                input {                 
                    rate 1;             
                }                       
                family inet {           
                    output {            
                        flow-server 172.10.10.203 {
                            port 2055;  
                            version-ipfix {
                                template {
                                    ipix;
                                }       
                            }           
                        }               
                        inline-jflow {  
                            source-address 172.10.10.10;
                            flow-export-rate 6;
                        }               
                    }                   
                }                       
            }                           
        }                               
    }                                   
}                                       
firewall {                              
    family inet {                       
        filter inet-sample {            
            term t1 {                   
                then {                  
                    sample;             
                    accept;             
                }                       
            }                           
        }                               
    }                                   
}
protocols {
    ospf {
        area 0.0.0.10 {
                interface ge-0/0/0;
                interface ge-0/0/1;
                interface ge-0/0/2;
        }
        lldp {                              
            interface all;                  
        }  
    }
}
