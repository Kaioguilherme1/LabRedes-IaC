sysname node3

info-center loghost 172.10.10.114

acl number 2001
 rule 5 permit source 172.10.10.0 0.0.0.255 

interface LoopBack0
 ip address 10.0.0.103 255.255.255.255
 
interface Ethernet1/0/0
 ip address 10.0.0.4 255.255.255.254
 ospf network-type p2p
 lldp enable
 ospf enable 1 area 0.0.0.10

interface Ethernet1/0/1
 ip address 10.0.0.3 255.255.255.254
 ospf network-type p2p
 lldp enable
 ospf enable 1 area 0.0.0.10


interface Ethernet1/0/9
 ip address 172.10.10.203 255.255.255.0
 lldp enable
 ospf enable 1 area 0.0.0.10

ospf 1 router-id 10.0.0.103
 area 0.0.0.10
