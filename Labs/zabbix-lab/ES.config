interfaces {
    ge-0/0/0 {
        unit 0 {
            family inet {
                address 10.0.0.67/31;
            }
            family inet6 {
                address fd00::67/127;
            }
        }
    }
    ge-0/0/1 {
        unit 0 {
            family inet {
                address 10.0.0.69/31;
            }
            family inet6 {
                address fd00::69/127;
            }
        }
    }
    ge-0/0/2 {
        unit 0 {
            family inet {
                address 10.0.0.133/31;
            }
            family inet6 {
                address fd00::133/127;
            }
        }
    }
    ge-0/0/3 {
        unit 0 {
            family inet {
                address 10.0.0.163/31;
            }
            family inet6 {
                address fd00::163/127;
            }
        }
    }
    lo0 {
        unit 0 {
            family inet {
                address 10.0.0.9/31;
            }
            family inet6 {
                address fd00::9/127;
            }
        }
    }
    ge-0/0/9 {
