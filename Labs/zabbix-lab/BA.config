snmp {                                  
    view all {                          
        oid .1;                         
    }                                   
    client-list 172.10.10.115;
    community public {                  
        view all;                       
        authorization read-write;       
        clients {                       
            172.10.10.0/24;             
        }                               
    }                                   
}
protocols {
    ospf {
        area 0.0.0.10 {
                interface ge-0/0/0;
                interface ge-0/0/1;
                interface ge-0/0/2;
                interface ge-0/0/3;
                interface ge-0/0/4;
