chassis {
    fpc 0 {
        sampling-instance instance-1;
        inline-services {
            flow-table-size {
                ipv4-flow-table-size 7;
            }
        }
    }
}
services {
    flow-monitoring {
        version-ipfix {
            template ipix {
                flow-active-timeout 100;
                flow-inactive-timeout 50;
                template-refresh-rate {
                    seconds 10;
                }
                ipv4-template;          
            }                           
        }                               
    }                                   
} 
interfaces {
    ge-0/0/0 {
        unit 0 {
            family inet {
                filter {
                    input inet-sample;
                }
                address 10.0.0.50/31;
            }
            family inet6 {
                address fd00::50/127;
            }
        }
    }
    ge-0/0/1 {
        unit 0 {
            family inet {
                filter {
                    input inet-sample;
                }
                address 10.0.0.52/31;
            }
            family inet6 {
                address fd00::52/127;
            }
        }
    }
    ge-0/0/2 {
        unit 0 {
            family inet {
                filter {
                    input inet-sample;
                }
                address 10.0.0.126/31;
            }
            family inet6 {
                address fd00::126/127;
            }
        }
    }
    ge-0/0/3 {
        unit 0 {
            family inet {
                filter {
                    input inet-sample;
                }
                address 10.0.0.75/31;
            }
            family inet6 {
                address fd00::75/127;
            }
        }
    }
    ge-0/0/4 {
        unit 0 {
            family inet {
                filter {
                    input inet-sample;
                }
                address 10.0.0.129/31;
            }
            family inet6 {
                address fd00::129/127;
            }
        }
    }
    ge-0/0/5 {
        unit 0 {
            family inet {
                filter {
                    input inet-sample;
                }
                address 10.0.0.155/31;
            }
            family inet6 {
                address fd00::155/127;
            }
        }
    }
    ge-0/0/6 {
        unit 0 {
            family inet {
                filter {
                    input inet-sample;
                }
                address 10.0.0.157/31;
            }
            family inet6 {
                address fd00::157/127;
            }
        }
    }
    lo0 {
        unit 0 {
            family inet {
                filter {
                    input inet-sample;
                }
                address 10.0.0.24/31;
            }
            family inet6 {
                address fd00::24/127;
            }
        }
    }
    ge-0/0/9 {
        unit 0 {
            family inet {
                address 172.10.10.24/24;
            }
        }
    }
}
forwarding-options {                    
    sampling {                          
        instance {                      
            instance-1 {                
                input {                 
                    rate 1;             
                }                       
                family inet {           
                    output {            
                        flow-server 172.10.10.110 {
                            port 2055;  
                            version-ipfix {
                                template {
                                    ipix;
                                }       
                            }           
                        }
                        flow-server 172.10.10.114 {
                            port 2055;
                            version-ipfix {
                                template {
                                    ipix;
                                }
                            }
                        }
                        inline-jflow {  
                            source-address 172.10.10.24;
                            flow-export-rate 6;
                        }               
                    }                   
                }                       
            }                           
        }                               
    }                                   
}                                       
firewall {                              
    family inet {                       
        filter inet-sample {            
            term t1 {                   
                then {                  
                    sample;             
                    accept;             
                }                       
            }                           
        }                               
    }                                   
}
snmp {
    view all {
        oid .1;
    }
    client-list 172.10.10.115;
    community public {
        view all;
        authorization read-write;
        clients {
            172.10.10.0/24;
        }
    }
}
protocols {
    ospf {
        area 0.0.0.10 {
                interface ge-0/0/0;
                interface ge-0/0/1;
                interface ge-0/0/2;
                interface ge-0/0/3;
                interface ge-0/0/4;
                interface ge-0/0/5;
                interface ge-0/0/6;
                interface lo0;
        }
    }
}