forwarding-options {                    
    sampling {                          
        instance {                      
            instance-1 {                
                input {                 
                    rate 1;             
                }                       
                family inet {           
                    output {            
                        flow-server 172.10.10.110 {
                            port 2055;  
                            version-ipfix {
                                template {
                                    ipix;
                                }       
                            }           
                        }
                        flow-server 172.10.10.114 {
                            port 2055;
                            version-ipfix {
                                template {
                                    ipix;
                                }
                            }
                        }
                        inline-jflow {  
                            source-address 172.10.10.37;
                            flow-export-rate 6;
                        }               
                    }                   
                }                       
            }                           
        }                               
    }                                   
}                                       
firewall {                              
    family inet {                       
        filter inet-sample {            
            term t1 {                   
                then {                  
                    sample;             
                    accept;             
                }                       
            }                           
        }                               
    }                                   
}
snmp {
    view all {
        oid .1;
    }
    client-list 172.10.10.115;
    community public {
        view all;
        authorization read-write;
        clients {
            172.10.10.0/24;
        }
    }
}
protocols {
    ospf {
        area 0.0.0.10 {
                interface ge-0/0/0;
                interface ge-0/0/1;
                interface ge-0/0/2;
                interface ge-0/0/3;
                interface ge-0/0/4;
                interface ge-0/0/5;
                interface ge-0/0/6;
                interface ge-0/0/7;
                interface ge-0/0/8;
                interface ge-0/0/9;
                interface ge-0/0/10;
                interface ge-0/0/11;
                interface ge-0/0/12;
                interface ge-0/0/13;
                interface ge-0/0/14;
                interface ge-0/0/15;
                interface lo0;
        }
    }
}